# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — SQLite for local dev (zero setup). For production use PostgreSQL (see README).
# Resolved relative to prisma/schema.prisma → prisma/dev.db
DATABASE_URL="file:./dev.db"

# Auth (required — run: openssl rand -base64 32)
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OpenAI (optional — AI captions/tags)
OPENAI_API_KEY=
